---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
const projectPath = (id: string) => id.replace(/\.md$/, "");
---

<Layout
  title="Selected work - Youssef Kader"
  description="Selected product design and development work by Youssef Kader."
>
  <main class="px-6 py-16 md:py-24">
    <div class="mx-auto max-w-7xl">
      <a href="/" class="mb-16 inline-block text-sm text-fg-secondary transition-colors hover:text-accent">&larr; Home</a>
      <h1 class="mb-16 text-5xl font-bold tracking-wide text-fg md:mb-24 md:text-7xl">Selected work.</h1>
      <div class="grid grid-cols-1 gap-x-8 gap-y-20 md:grid-cols-2">
        {projects.map((project) => (
          <a href={`/work/${projectPath(project.id)}`} class="group block">
            <div class="mb-6 overflow-hidden rounded-3xl bg-surface">
              <Image src={project.data.cover} alt={`${project.data.title} project cover`} class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
            </div>
            <p class="mb-4 text-xs uppercase tracking-widest text-fg-secondary">{project.data.dateRange}</p>
            <h2 class="text-3xl font-bold leading-tight tracking-wide md:text-4xl">
              <span class="text-fg">{project.data.title} &mdash; </span><span class="text-fg-secondary">{project.data.tagline}.</span>
            </h2>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
