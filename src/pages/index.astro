---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Token Test — youssefkader.me</title>
  </head>
  <body class="transition-colors duration-300">
    <!-- Theme Toggle -->
    <button
      id="theme-toggle"
      class="fixed top-6 right-6 z-50 flex items-center gap-2 bg-elevated border border-border px-4 py-2 rounded-full text-body-sm font-semibold text-fg hover:border-border-strong transition-all duration-300 cursor-pointer"
    >
      <span id="toggle-icon" class="text-[20px]">☀️</span>
      <span id="toggle-label">Light mode</span>
    </button>

    <main class="mx-auto max-w-5xl p-16 space-y-16">
      <!-- Hero -->
      <section class="space-y-4">
        <p class="text-label uppercase tracking-wider text-fg-muted">
          Token Test Page
        </p>
        <h1 class="text-display text-fg">From idea to digital product.</h1>
        <p class="text-body-lg text-fg-secondary max-w-2xl">
          Helping agencies and founders launch websites, apps, and brands — from
          strategy to design to development.
        </p>
        <div class="flex gap-4 pt-4">
          <button
            class="bg-accent text-accent-fg px-6 py-3 rounded-lg text-body-md font-semibold hover:bg-accent-hover transition-colors duration-200 cursor-pointer"
          >
            Book a call
          </button>
          <button
            class="border border-accent text-accent px-6 py-3 rounded-lg text-body-md font-semibold hover:bg-accent/10 transition-colors duration-200 cursor-pointer"
          >
            View my work →
          </button>
        </div>
      </section>

      <!-- Type Scale -->
      <section class="space-y-4">
        <h2 class="text-h2">Type scale</h2>
        <div class="space-y-2 bg-surface border border-border rounded-lg p-8">
          <p class="text-display">Display 72</p>
          <p class="text-h1">H1 56</p>
          <p class="text-h2">H2 40</p>
          <p class="text-h3">H3 32</p>
          <p class="text-h4">H4 24</p>
          <p class="text-h5">H5 20</p>
          <p class="text-body-lg">Body Large — 18px regular</p>
          <p class="text-body-md text-fg-secondary">
            Body Medium — 16px regular
          </p>
          <p class="text-body-sm text-fg-muted">Body Small — 14px regular</p>
          <p class="text-caption text-fg-muted">Caption — 12px regular</p>
          <p class="text-label uppercase tracking-wider text-fg-muted">
            Label — 12px semibold
          </p>
        </div>
      </section>

      <!-- Blue Scale -->
      <section class="space-y-4">
        <h2 class="text-h2">Blue scale</h2>
        <div class="grid grid-cols-10 gap-2">
          <div class="h-20 bg-blue-50 rounded-md"></div>
          <div class="h-20 bg-blue-100 rounded-md"></div>
          <div class="h-20 bg-blue-200 rounded-md"></div>
          <div class="h-20 bg-blue-300 rounded-md"></div>
          <div class="h-20 bg-blue-400 rounded-md"></div>
          <div class="h-20 bg-blue-500 rounded-md"></div>
          <div class="h-20 bg-blue-600 rounded-md"></div>
          <div class="h-20 bg-blue-700 rounded-md"></div>
          <div class="h-20 bg-blue-800 rounded-md"></div>
          <div class="h-20 bg-blue-900 rounded-md"></div>
        </div>
      </section>

      <!-- Grey Scale -->
      <section class="space-y-4">
        <h2 class="text-h2">Grey scale</h2>
        <div class="grid grid-cols-12 gap-2">
          <div class="h-20 bg-grey-0 rounded-md border border-border"></div>
          <div class="h-20 bg-grey-50 rounded-md"></div>
          <div class="h-20 bg-grey-100 rounded-md"></div>
          <div class="h-20 bg-grey-200 rounded-md"></div>
          <div class="h-20 bg-grey-300 rounded-md"></div>
          <div class="h-20 bg-grey-400 rounded-md"></div>
          <div class="h-20 bg-grey-500 rounded-md"></div>
          <div class="h-20 bg-grey-600 rounded-md"></div>
          <div class="h-20 bg-grey-700 rounded-md"></div>
          <div class="h-20 bg-grey-800 rounded-md"></div>
          <div class="h-20 bg-grey-900 rounded-md"></div>
          <div class="h-20 bg-grey-950 rounded-md"></div>
        </div>
      </section>

      <!-- Semantic Colors -->
      <section class="space-y-4">
        <h2 class="text-h2">Semantic</h2>
        <div class="grid grid-cols-3 gap-4 max-w-2xl">
          <div
            class="h-20 bg-feedback-success rounded-md flex items-center justify-center text-grey-0 text-label"
          >
            success
          </div>
          <div
            class="h-20 bg-feedback-error rounded-md flex items-center justify-center text-grey-0 text-label"
          >
            error
          </div>
          <div
            class="h-20 bg-feedback-warning rounded-md flex items-center justify-center text-grey-0 text-label"
          >
            warning
          </div>
        </div>
      </section>

      <!-- Surface Preview -->
      <section class="space-y-4">
        <h2 class="text-h2">Surfaces & borders</h2>
        <div class="grid grid-cols-3 gap-4">
          <div
            class="bg-primary border border-border rounded-lg p-6 space-y-2"
          >
            <p class="text-label uppercase tracking-wider text-fg-muted">
              bg-primary
            </p>
            <p class="text-body-md text-fg">Primary background</p>
            <p class="text-body-sm text-fg-secondary">
              Secondary text on primary
            </p>
          </div>
          <div class="bg-surface border border-border rounded-lg p-6 space-y-2">
            <p class="text-label uppercase tracking-wider text-fg-muted">
              bg-surface
            </p>
            <p class="text-body-md text-fg">Surface background</p>
            <p class="text-body-sm text-fg-secondary">
              Secondary text on surface
            </p>
          </div>
          <div
            class="bg-elevated border border-border-strong rounded-lg p-6 space-y-2"
          >
            <p class="text-label uppercase tracking-wider text-fg-muted">
              bg-elevated
            </p>
            <p class="text-body-md text-fg">Elevated background</p>
            <p class="text-body-sm text-fg-secondary">
              Secondary text on elevated
            </p>
          </div>
        </div>
      </section>
    </main>

    <script>
      const toggle = document.getElementById("theme-toggle");
      const icon = document.getElementById("toggle-icon");
      const label = document.getElementById("toggle-label");
      const html = document.documentElement;

      function setTheme(theme: string) {
        if (theme === "light") {
          html.setAttribute("data-theme", "light");
          icon.textContent = "🌙";
          label.textContent = "Dark mode";
        } else {
          html.removeAttribute("data-theme");
          icon.textContent = "☀️";
          label.textContent = "Light mode";
        }
        localStorage.setItem("theme", theme);
      }

      // Init from localStorage
      const saved = localStorage.getItem("theme") || "dark";
      setTheme(saved);

      toggle.addEventListener("click", () => {
        const current = html.getAttribute("data-theme");
        setTheme(current === "light" ? "dark" : "light");
      });
    </script>
  </body>
</html>
